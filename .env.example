# Copy to .env and fill in your Tigris Data bucket credentials.
# bin/dev-start sources .env before starting the JVM.

# Existing app config, if needed:
# export WORKOS_CLIENT_ID=
# export WORKOS_API_KEY=
# export WORKOS_REDIRECT_URI=http://localhost:8080/auth/callback
# export COOKIE_DOMAIN=.localhost

# Tigris-backed S3 event store:
export EVENT_STORE_BUCKET=your-tigris-bucket
export EVENT_STORE_PREFIX=todo/dev
export EVENT_STORE_ENDPOINT=https://t3.storage.dev
export EVENT_STORE_REGION=auto
export EVENT_STORE_ACCESS_KEY_ID=your-access-key-id
export EVENT_STORE_SECRET_ACCESS_KEY=your-secret-access-key
